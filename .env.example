# Anthropic provider. Required when an agent uses provider = anthropic.
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# Optional custom Anthropic-compatible endpoint.
# ANTHROPIC_BASE_URL=

# OpenRouter provider. Required when an agent uses provider = openrouter.
# OPENROUTER_API_KEY=sk-or-your-key-here
# Optional custom OpenRouter-compatible endpoint.
# OPENROUTER_BASE_URL=

# OpenAI-compatible provider. Use this for OpenAI or any /v1/chat/completions compatible service.
# OPENAI_COMPATIBLE_API_KEY=
# Optional custom base URL. Leave empty for https://api.openai.com/v1.
# OPENAI_COMPATIBLE_BASE_URL=

# Example: DeepSeek V4 on OpenRouter, with Qwen embeddings for memory.
# .env:
# OPENROUTER_API_KEY=sk-or-your-key-here
#
# Web settings:
# Agent provider = openrouter
# Agent model = deepseek/deepseek-v4-flash
# Memory embedding provider = openrouter
# Memory embedding model = qwen/qwen3-embedding-8b
#
# For a stronger DeepSeek V4 model, use deepseek/deepseek-v4-pro if it is available on OpenRouter.

# Example: DeepSeek through the Anthropic-compatible provider.
# .env:
# ANTHROPIC_API_KEY=sk-your-deepseek-key
# ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
#
# Web settings:
# Agent provider = anthropic
# Agent model = deepseek-chat
