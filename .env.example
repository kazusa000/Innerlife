ANTHROPIC_API_KEY=sk-ant-your-key-here

# 可选：指向 Anthropic 兼容的第三方 endpoint（DeepSeek / Moonshot 等）
# DeepSeek: https://api.deepseek.com/anthropic
# 留空则走官方 https://api.anthropic.com
# ANTHROPIC_BASE_URL=

# OpenRouter provider（当 agent.provider = openrouter 时使用）
# OPENROUTER_API_KEY=sk-or-your-key-here
# 留空则走官方 https://openrouter.ai/api/v1
# OPENROUTER_BASE_URL=
# 可选：用于 OpenRouter 控制台归因
# OPENROUTER_SITE_URL=http://localhost:3000
# OPENROUTER_SITE_NAME=multi-agent-system

# OpenAI-compatible provider（当 agent.provider = openai-compatible 时使用）
# 支持 OpenAI 官方 API，也支持暴露 /v1/chat/completions 的本地或第三方服务。
# OPENAI_COMPATIBLE_API_KEY=
# 留空则走官方 https://api.openai.com/v1
# OPENAI_COMPATIBLE_BASE_URL=
